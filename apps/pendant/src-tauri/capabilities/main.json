{
  "$schema": "https://schema.tauri.app/capability/2",
  "identifier": "main",
  "description": "Main window capabilities",
  "remote": {
    "urls": [
      "http://127.0.0.1:*/*",
      "http://localhost:*/*",
      "http://*:*/*",
      "https://*:*/*"
    ]
  },
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "opener:default"
  ]
}
