{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "com.sienci.gsender-pendant",
  "productName": "gSender Pendant",
  "version": "0.1.0",
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "gSender Pendant",
        "width": 1024,
        "height": 768,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "url": "http://127.0.0.1:8000/pendant"
      }
    ],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../../../electron-build/icon-square.png",
      "../../../electron-build/icon-edge.icns",
      "../../../electron-build/icon-edge.ico"
    ],
    "category": "Utility",
    "shortDescription": "Touch-first pendant UI for gSender CNC controller"
  }
}
