{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "com.sienci.gsender-pendant",
  "build": {
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": "bun run dev"
  },
  "productName": "gSender Pendant",
  "version": "0.1.0",
  "app": {
    "withGlobalTauri": false,
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../../../electron-build/icon-square.png",
      "../../../electron-build/icon-edge.icns",
      "../../../electron-build/icon-edge.ico"
    ],
    "category": "Utility",
    "shortDescription": "Touch-first pendant UI for gSender CNC controller",
    "externalBin": ["binaries/gsender-server"],
    "resources": {
      "binaries/pendant": "pendant",
      "binaries/prebuilds": "prebuilds"
    },
    "macOS": {
      "entitlements": "entitlements.plist"
    }
  }
}
