{
    "compilerOptions": {
        "target": "ES2021",
        "useDefineForClassFields": true,
        "lib": [
            "ES2021",
            "DOM",
            "DOM.Iterable",
            "esnext"
        ],
        "module": "ESNext",
        // "module": "CommonJS",
        "skipLibCheck": true,
        "esModuleInterop": true,
        "incremental": true,
        "allowJs": true,
        /* Bundler mode */
        "moduleResolution": "Bundler",
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "jsx": "react-jsx",
        "strict": true,
        "strictNullChecks": false, // this is so we can assign variables as null before defining them
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noUncheckedIndexedAccess": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitAny": true,
        "forceConsistentCasingInFileNames": true,
        "typeRoots": [
            "./node_modules/@types",
            "./src/declarations.d.ts"
        ],
        "baseUrl": ".",
        "paths": {
            "app/*": [
                "src/*"
            ],
            "app-root/*": [
                "../../*"
            ],
            "@gsender/features/*": [
                "../../packages/features/src/*"
            ],
            "@gsender/features": [
                "../../packages/features/src/index.ts"
            ],
            "@gsender/controller-client": [
                "../../packages/controller-client/src/index.ts"
            ],
            "@gsender/controller-client/controller": [
                "../../packages/controller-client/src/controller.ts"
            ],
            "@gsender/controller-client/store/redux": [
                "../../packages/controller-client/src/store/redux/index.ts"
            ],
            "@gsender/controller-client/store/definitions": [
                "../../packages/controller-client/src/store/definitions.ts"
            ],
            "@gsender/controller-client/store/*": [
                "../../packages/controller-client/src/store/*"
            ],
            "@gsender/controller-client/hooks/*": [
                "../../packages/controller-client/src/hooks/*"
            ],
            "@gsender/ui": [
                "../../packages/ui/src/index.ts"
            ],
            "@gsender/ui/shadcn/*": [
                "../../packages/ui/src/shadcn/*"
            ],
            "@gsender/ui/primitives/*": [
                "../../packages/ui/src/primitives/*"
            ],
            "@gsender/ui/form/*": [
                "../../packages/ui/src/form/*"
            ],
            "@gsender/ui/lib/*": [
                "../../packages/ui/src/lib/*"
            ]
        }
    },
    "ts-node": {
        "esm": true
    },
    "include": [
        "vite.config.ts",
        "declaration.d.ts",
        "**/*.ts",
        "**/*.tsx",
        "**/*.cjs",
        "**/*.mjs"
    ],
    "exclude": [
        "output"
    ]
    // "references": [{ "path": "./tsconfig.node.json" }]
}