{
  "name": "gSender",
  "version": "1.6.0-Edge-4",
  "description": "Electron sender for GRBL based CNC machines",
  "author": {
    "name": "Sienci Labs <hi@sienci.com>",
    "email": "hi@sienci.com"
  },
  "main": "./dist/gsender/server-cli",
  "types": "./dist/gsender/server-cli",
  "bin": {
    "cnc": "./bin/cnc",
    "gsender": "./bin/gsender"
  },
  "files": [
    "bin",
    "dist",
    "static"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Sienci-Labs/gsender"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "preferGlobal": true,
  "scripts": {
    "prepare": "npm run clean",
    "prebuild-latest": "npm run package-sync && bash -c \"cd src; npm version ${npm_package_version}-${COMMIT_COUNT} --allow-same-version\" && node esbuild.config.js --prebuild-only --production",
    "prebuild-dev": "npm run package-sync && node esbuild.config.js --prebuild-only",
    "prebuild-prod": "npm run package-sync && node esbuild.config.js --prebuild-only --production",
    "build": "npm run build-prod",
    "build-latest": "concurrently --kill-others-on-fail --names \"build-dev-css,build-prod-server,vite:build\" \"npm run build-dev-css\" \"npm run build-prod-server\" \"npm run vite:build\" && npm run copy-css",
    "build-dev": "concurrently --kill-others-on-fail --names \"build-dev-css,build-dev-server\" \"npm run build-dev-server\" \"npm run build-dev-css\"",
    "build-dev-server": "node esbuild.config.js --target=all",
    "build-dev-css": "postcss src/app/src/index.css -o src/app/src/application.css",
    "build-prod": "concurrently --kill-others-on-fail --names \"build-dev-css,build-prod-server,vite:build\" \"npm run build-dev-css\" \"npm run build-prod-server\" \"npm run vite:build\" && npm run copy-css",
    "build-prod-server": "node esbuild.config.js --production --target=all",
    "copy-css": "cross-env mkdir -p dist/gsender/app/src && cp src/app/src/application.css dist/gsender/app/src/",
    "postbuild-dev-server": "echo 'Static files copied by esbuild'",
    "postbuild-prod-server": "echo 'Static files copied by esbuild'",
    "clean": "bash -c 'rm -rf ./dist ./output'",
    "tailwind-dev": "npx tailwindcss -i src/app/src/index.css -o src/app/src/application.css --watch",
    "electron": "electron",
    "electron-builder": "electron-builder",
    "electron-builder:debug": "cross-env DEBUG=electron-builder electron-builder",
    "github-release": "github-release",
    "electron-rebuild": "electron-rebuild",
    "package-sync": "node scripts/package-sync.js",
    "build:macos": "bash -c 'scripts/electron-builder.sh --macos --x64 --arm64'",
    "build:macos-x64": "bash -c 'scripts/electron-builder.sh --macos --x64'",
    "build:macos-arm64": "bash -c 'scripts/electron-builder.sh --macos --arm64'",
    "build:linux-ia32": "bash -c 'scripts/electron-builder.sh --linux --ia32'",
    "build:linux-x64": "bash -c 'scripts/electron-builder.sh --linux --x64'",
    "build:linux-armv7l": "bash -c 'scripts/electron-builder.sh --linux --armv7l'",
    "build:linux": "bash -c 'scripts/electron-builder.sh --linux --x64 --arm64'",
    "build:linux-arm64": "bash -c 'scripts/electron-builder.sh --linux --arm64'",
    "build:windows-ia32": "bash -c 'scripts/electron-builder.sh --windows --ia32'",
    "build:windows-x64": "bash -c 'scripts/electron-builder.sh --windows --x64'",
    "build:windows": "bash -c 'scripts/electron-builder.sh --windows --x64'",
    "start": "cross-env ./bin/gsender",
    "start-electron": "electron ./dist/gsender/main",
    "watch-dev": "node esbuild.config.js --watch",
    "start-dev": "cross-env NODE_ENV=development ./bin/gsender -vv -p 8000",
    "start-dev:nodemon": "nodemon --exec \"node ./bin/gsender -vv -p 8000\"",
    "dev": "npm run prebuild-dev && npm run build-dev-server && concurrently --kill-others-on-fail --names \"esbuild,server,tailwind\" \"npm run watch-dev\" \"npm run start-dev:nodemon\" \"npm run tailwind-dev\"",
    "vite:dev": "cd src/app && vite --port 5173 --host",
    "electron:dev": "npm run electron:hot",
    "electron:hot": "npm run build-dev && concurrently --kill-others-on-fail --names \"esbuild,server,vite,electron\" \"npm run watch-dev\" \"npm run start-dev:nodemon\" \"npm run vite:dev\" \"bash -lc 'until curl -sf http://127.0.0.1:5173 >/dev/null; do sleep 0.2; done; cross-env NODE_ENV=development ELECTRON_RENDERER_URL=http://127.0.0.1:5173 electron ./output/main'\"",
    "prod": "npm run build-prod && NODE_ENV=production ./bin/gsender",
    "lint": "concurrently --kill-others-on-fail --names \"eslint,stylint\" \"yarn run eslint\" \"yarn run stylint\"",
    "eslint": "npm run eslint:build",
    "eslint:build": "eslint --ext .js --ext .jsx *.js scripts test --fix",
    "eslint:debug": "echo \"Checking code style...\"; DEBUG=eslint:cli-engine eslint --ext .js --ext .jsx *.js src scripts test",
    "stylint": "stylint src/app",
    "cypress:open": "cypress open",
    "cy:run": "cypress run",
    "report:merge": "mochawesome-merge cypress/reports/mocha/*.json > cypress/reports/mochawesome.json",
    "report:generate": "marge cypress/reports/mochawesome.json -f index -o cypress/reports"
  },
  "build": {
    "appId": "org.sienci.gsender-edge",
    "extraMetadata": {
      "main": "./main.js"
    },
    "afterSign": "./notarize.js",
    "extends": null,
    "artifactName": "${name}-${version}-${arch}.${ext}",
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "**/*.{dll,so,dylib,exe}"
    ],
    "productName": "gSender Edge",
    "generateUpdatesFilesForAllChannels": true,
    "npmRebuild": false,
    "compression": "normal",
    "removePackageScripts": true,
    "buildDependenciesFromSource": false,
    "files": [
      "**/*",
      "!**/*.map"
    ],
    "extraResources": [
      "./node_modules/@electron/remote/**"
    ],
    "directories": {
      "buildResources": "electron-build",
      "output": "output",
      "app": "dist/gsender"
    },
    "nsis": {
      "allowToChangeInstallationDirectory": true,
      "oneClick": false,
      "license": "LICENSE",
      "perMachine": true,
      "installerSidebar": "electron-build/sidebar.bmp",
      "createDesktopShortcut": false,
      "createStartMenuShortcut": false,
      "include": "electron-build/installer.nsh"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg"
      ],
      "icon": "electron-build/icon.icns",
      "electronUpdaterCompatibility": ">=2.16",
      "darkModeSupport": true,
      "mergeASARs": false,
      "hardenedRuntime": true,
      "entitlements": "electron-build/entitlements.mac.plist",
      "entitlementsInherit": "electron-build/entitlements.mac.plist"
    },
    "dmg": {
      "background": "electron-build/background.png",
      "icon": "electron-build/icon.icns",
      "iconSize": 80,
      "iconTextSize": 12,
      "writeUpdateInfo": false,
      "contents": [
        {
          "x": 448,
          "y": 344,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 192,
          "y": 344,
          "type": "file"
        }
      ]
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "electron-build/icon.ico"
    },
    "linux": {
      "category": "Utility",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "keywords": [
    "gsender",
    "arduino",
    "raspberry",
    "pi",
    "cnc",
    "gcode",
    "grbl",
    "grblhal",
    "react",
    "socket.io"
  ],
  "dependencies": {
    "@electron/remote": "^2.1.3",
    "@sentry/electron": "^6.6.0",
    "@sentry/react": "^9.28.0",
    "@serialport/parser-byte-length": "^11.0.0",
    "@serialport/parser-readline": "^11.0.0",
    "@sienci/avrgirl-arduino": "^5.0.3",
    "axios": "^1.2.4",
    "basic-ftp": "^5.1.0",
    "bcrypt-nodejs": "0.0.3",
    "buffer-chunks": "^0.1.1",
    "chalk": "~2.4.2",
    "commander": "^10.0.0",
    "compression": "^1.8.1",
    "connect-restreamer": "~1.0.3",
    "consolidate": "~0.15.1",
    "cookie-parser": "~1.4.4",
    "cors": "^2.8.5",
    "crc-full": "^1.1.0",
    "debug": "^4.4.3",
    "deep-keys": "~0.5.0",
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.7.3",
    "ensure-array": "~1.0.0",
    "errorhandler": "~1.5.0",
    "escodegen": "~1.11.1",
    "esprima": "~4.0.1",
    "expand-tilde": "~2.0.2",
    "express": "^4.22.1",
    "express-jwt": "5",
    "express-session": "^1.19.0",
    "gcode-interpreter": "~2.1.0",
    "gcode-parser": "~1.3.6",
    "hogan.js": "~3.0.2",
    "http-proxy": "~1.18.1",
    "i18next": "~15.0.9",
    "i18next-fs-backend": "^1.1.4",
    "i18next-http-middleware": "^3.2.1",
    "is-electron": "^2.2.2",
    "is-online": "^12.0.2",
    "jsonfile": "^6.2.0",
    "jsonwebtoken": "^9.0.3",
    "lodash": "~4.17.11",
    "method-override": "~3.0.0",
    "minimatch": "^10.2.2",
    "mkdirp": "~0.5.1",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "nrf-intel-hex": "^1.3.0",
    "range_check": "~1.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "registry-auth-token": "~3.4.0",
    "registry-url": "~5.1.0",
    "rimraf": "^6.1.3",
    "serialport": "^13.0.0",
    "serve-favicon": "~2.5.0",
    "serve-static": "~1.13.2",
    "session-file-store": "^1.5.0",
    "shortid": "~2.2.14",
    "sirv": "^2.0.4",
    "socket.io": "^4.1.3",
    "spawn-default-shell": "~2.0.0",
    "superagent": "^6.1.0",
    "usb": "^2.17.0",
    "uuid": "~3.3.2",
    "watch": "^0.13.0",
    "webappengine": "~1.2.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.27.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "cypress": "^13.4.0",
    "cypress-grep": "^3.0.4",
    "cypress-mochawesome-reporter": "^4.0.2",
    "cypress-real-events": "^1.15.0",
    "dotenv": "^17.3.1",
    "electron": "^40.6.0",
    "esbuild": "^0.27.3",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^25.0.0",
    "jest-environment-jsdom": "^30.2.0",
    "marge": "^1.0.1",
    "mochawesome": "^4.1.0",
    "mochawesome-merge": "^5.1.1",
    "mochawesome-report-generator": "^6.3.2",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.6",
    "tailwindcss": "3",
    "tailwindcss-animate": "^1.0.7",
    "ts-jest": "^29.1.2",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1"
  },
  "packageManager": "yarn@1.22.22"
}
