{
  "appId": "org.sienci.gsender-pendant",
  "productName": "gSender Pendant",
  "extends": null,
  "afterSign": "./notarize.js",
  "artifactName": "gSender-Pendant-${version}-${arch}.${ext}",
  "asar": true,
  "asarUnpack": [
    "**/*.node",
    "**/*.{dll,so,dylib,exe}"
  ],
  "extraMetadata": {
    "main": "./pendant-main.js"
  },
  "generateUpdatesFilesForAllChannels": false,
  "npmRebuild": false,
  "compression": "normal",
  "removePackageScripts": true,
  "buildDependenciesFromSource": false,
  "files": [
    "**/*",
    "!**/*.map"
  ],
  "extraResources": [
    "./node_modules/@electron/remote/**"
  ],
  "directories": {
    "buildResources": "electron-build",
    "output": "output-pendant",
    "app": "dist/gsender-pendant"
  },
  "mac": {
    "category": "public.app-category.productivity",
    "target": [
      "dmg"
    ],
    "icon": "electron-build/icon-pendant.icns",
    "darkModeSupport": true,
    "mergeASARs": false,
    "hardenedRuntime": true,
    "entitlements": "electron-build/entitlements.mac.plist",
    "entitlementsInherit": "electron-build/entitlements.mac.plist"
  },
  "dmg": {
    "icon": "electron-build/icon.icns",
    "iconSize": 80,
    "iconTextSize": 12,
    "writeUpdateInfo": false,
    "contents": [
      {
        "x": 448,
        "y": 344,
        "type": "link",
        "path": "/Applications"
      },
      {
        "x": 192,
        "y": 344,
        "type": "file"
      }
    ]
  },
  "linux": {
    "category": "Utility",
    "icon": "electron-build/icon-pendant.png",
    "target": [
      "deb"
    ]
  }
}
